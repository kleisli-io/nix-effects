# Step-contract generator: measures each probe's per-level slope from the live
# evaluator and emits the budgets.toml work-axis fragment. Slopes are computed,
# never hand-typed — regenerate after an intentional per-step cost change.
{ benchPath }:

let
  bench = import benchPath { };

  # stepSlope truncates; a non-integer slope means the probe is not linear in n
  # and the declared contract would be silently wrong.
  slopeFor = name:
    let
      probe = bench.stepProbes.${name};
      slope = bench.measure.stepSlope probe;
      exact = probe.hi.steps - probe.lo.steps == slope * (probe.hi.n - probe.lo.n);
    in
    if exact then slope
    else throw "step-budgets: probe ${name} slope is not an integer — probe not linear in n";

  probeNames = builtins.attrNames bench.stepProbes;
  slopes = builtins.listToAttrs
    (map (name: { inherit name; value = slopeFor name; }) probeNames);

  slopeLines = map (name: "\"${name}\" = ${toString slopes.${name}}") probeNames;

  toml = ''
    # Tight tolerance (‰) for the CEK step-count work axis. The count is an
    # exact, representation-invariant law of term + evaluator (zero measurement
    # noise); 5‰ absorbs only benign constant-factor step re-decomposition.
    stepSlopeTolerancePermille = 5

    # Per-level transition slopes measured from the live step probes
    # (bench/step-probes.nix). Generated by bench/runner/step-budgets.nix —
    # do not hand-edit.
    [stepSlopes]
    ${builtins.concatStringsSep "\n" slopeLines}
  '';
in
{ inherit toml slopes; }
